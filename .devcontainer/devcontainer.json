{
  "name": "ML Project Books",
  "dockerComposeFile": "./docker-compose.yml",
  "service": "ml-env-books",
  "workspaceFolder": "/app",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "mermaidchart.vscode-mermaid-chart"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.analysis.typeCheckingMode": "basic",
        "jupyter.askForKernelRestart": false
      }
    }
  },

  "postCreateCommand": "pip install --no-cache-dir ipykernel",

  // "forwardPorts": [8889],

  "remoteUser": "root"
}
